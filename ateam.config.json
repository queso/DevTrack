{
  "packageManager": "pnpm",
  "checks": {
    "lint": "cd web && pnpm run lint",
    "unit": "cd web && pnpm test",
    "e2e": "cd web && pnpm run test:e2e"
  },
  "precheck": ["lint", "unit"],
  "postcheck": ["lint", "unit", "e2e"],
  "devServer": {
    "url": "https://kanban.theaiteam.dev/",
    "start": "pnpm run dev",
    "restart": "docker compose restart",
    "managed": false
  }
}
