# Required. PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://dev_track:dev_track@localhost:5432/dev_track

# Pino log level. Valid values: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Canonical site URL used for sitemap, robots.txt, and Open Graph metadata (default: http://localhost:3000)
SITE_URL=http://localhost:3000

# Allowed origin for CORS requests. Set to "*" for any origin, or a specific URL.
# Leave empty for same-origin only (default: "")
CORS_ORIGIN=

# Max API requests per minute per IP address (default: 60)
RATE_LIMIT_RPM=60
